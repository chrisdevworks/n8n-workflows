          "value": {
            "Date": "={{ $json.generated_at }}",
            "Keyword": "={{ $json.brief.keyword }}",
            "Search Intent": "={{ $json.brief.search_intent }}",
            "Target Word Count": "={{ $json.brief.target_word_count }}",
            "Title Suggestion 1": "={{ $json.brief.seo_title_suggestions[0] }}",
            "Title Suggestion 2": "={{ $json.brief.seo_title_suggestions[1] }}",
            "Title Suggestion 3": "={{ $json.brief.seo_title_suggestions[2] }}",
            "Meta Description": "={{ $json.brief.meta_description }}",
            "Secondary Keywords": "={{ $json.brief.secondary_keywords.join(', ') }}",
            "LSI Keywords": "={{ $json.brief.lsi_keywords.join(', ') }}",
