    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an expert SEO strategist. A user has submitted the following request:\n\n- **Keyword / Topic:** {{ $json.body.keyword }}\n- **Target Audience:** {{ $json.body.target_audience }}\n- **Content Type:** {{ $json.body.content_type }}\n\nGenerate a detailed SEO Content Brief in valid JSON using this exact structure:\n{\n  \"keyword\": \"<primary keyword>\",\n  \"seo_title_suggestions\": [\"<title 1>\", \"<title 2>\", \"<title 3>\"],\n  \"meta_description\": \"<150-160 character meta description>\",\n  \"target_word_count\": <number>,\n  \"search_intent\": \"<informational | transactional | navigational | commercial>\",\n  \"secondary_keywords\": [\"<kw1>\", \"<kw2>\", \"<kw3>\", \"<kw4>\", \"<kw5>\"],\n  \"lsi_keywords\": [\"<lsi1>\", \"<lsi2>\", \"<lsi3>\"],\n  \"content_outline\": [\n    { \"section\": \"Introduction\", \"notes\": \"<brief guidance>\" },\n    { \"section\": \"<H2 heading>\", \"notes\": \"<brief guidance>\" },\n    { \"section\": \"<H2 heading>\", \"notes\": \"<brief guidance>\" },\n    { \"section\": \"<H2 heading>\", \"notes\": \"<brief guidance>\" },\n    { \"section\": \"FAQs\", \"notes\": \"List 3 common questions and short answers\" },\n    { \"section\": \"Conclusion\", \"notes\": \"<brief guidance>\" }\n  ],\n  \"internal_link_opportunities\": [\"<topic 1>\", \"<topic 2>\"],\n  \"cta_suggestion\": \"<recommended call-to-action>\"\n}\n\nReturn ONLY the JSON object. No markdown, no explanation, no extra text.",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [-100, 0],
      "id": "a1b2c3d4-0002-4000-8000-000000000002",
      "name": "AI SEO Brief Generator"
    },
    {
      "parameters": {
        "model": "claude-haiku-4-5-20251001",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [-100, 240],
      "id": "a1b2c3d4-0003-4000-8000-000000000003",
      "name": "Claude Haiku",
      "credentials": {
        "anthropicApi": {
          "id": "anthropic-credentials-id",
          "name": "Anthropic account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rawOutput = $input.first().json.output;\n\nlet brief;\ntry {\n  const cleaned = rawOutput.replace(/```json\\n?|```/g, '').trim();\n  brief = JSON.parse(cleaned);\n} catch (e) {\n  return [{ json: { error: 'Failed to parse AI output', raw: rawOutput } }];\n}\n\nreturn [\n  {\n    json: {\n      success: true,\n      generated_at: new Date().toISOString(),\n      brief\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [200, 0],
      "id": "a1b2c3d4-0004-4000-8000-000000000004",
      "name": "Parse & Format Output"
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
